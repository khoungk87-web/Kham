<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>my favorite food</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <!-- Navigation -->
  <nav class="navbar">
    <div class="logo">Alex Developer</div>
    <ul class="nav-links">
      <li><a href="#about">About</a></li>
      <li><a href="#projects">Projects</a></li>
      <li><a href="#skills">Skills</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
  </nav>

  <!-- Hero / About Section -->
  <section id="about" class="hero">
    <div class="hero-content">
      <h1>Hi, I'm <span class="highlight">Alex</span> 👋</h1>
      <p>I build clean, user-friendly, and interactive web experiences.</p>
      <a href="#projects" class="btn">View My Work</a>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="section">
    <h2>Featured Projects</h2>
    <div class="projects-grid">
      
      <div class="project-card">
        <h3>E-Commerce Dashboard</h3>
        <p>A responsive dashboard with dynamic charts and light/dark theme support.</p>
        <div class="tags">
          <span>HTML</span><span>CSS</span><span>JavaScript</span>
        </div>
      </div>

      <div class="project-card">
        <h3>Task Tracker App</h3>
        <p>A simple task management tool built to organize daily routines efficiently.</p>
        <div class="tags">
          <span>JavaScript</span><span>DOM API</span><span>LocalStorage</span>
        </div>
      </div>

      <div class="project-card">
        <h3>Weather Forecast Hub</h3>
        <p>Real-time weather tracking app using external REST APIs.</p>
        <div class="tags">
          <span>Fetch API</span><span>CSS Grid</span>
        </div>
      </div>

    </div>
  </section>

  <!-- Skills Section -->
  <section id="skills" class="section gray-bg">
    <h2>Skills & teacher</h2>
    <ul class="skills-list">
      <li>HTML5 & CSS3</li>
      <li>JavaScript (ES6+)</li>
      <li>Responsive Design</li>
      <li>Git & GitHub</li>
      <li>REST APIs</li>
    </ul>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="section">
    <h2>Get In Touch</h2>
    <form id="contact-form" class="contact-form">
      <input type="text" id="name" placeholder="Your Name" required>
      <input type="email" id="email" placeholder="Your Email" required>
      <textarea id="message" rows="5" placeholder="Your Message" required></textarea>
      <button type="submit" class="btn">Send Message</button>
    </form>
    <p id="form-status"></p>
  </section>

  <footer>
    <p>&copy; 2026 Alex Developer. All rights reserved.</p>
  </footer>

  <script src="script.js"></script>
</body>
</html>
